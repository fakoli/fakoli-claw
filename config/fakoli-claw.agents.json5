// fakoli-claw — OpenClaw agents config (Phase A: the crew as agents).
//
// Merge into ~/.openclaw/openclaw.json, or run scripts/install.sh (creates the
// per-agent workspaces, copies each AGENTS.md prompt, then patches config).
//
// Tier routing (re-tune freely):
//   quality tier      -> openai/gpt-5.5       : orchestrator, guido, critic, sentinel
//   efficient tier    -> openai/gpt-5.4-mini  : welder, smith, scout, herald, keeper
//
// Each agent's system prompt is its workspace AGENTS.md (the canonical crew
// prompt, shipped under agents/<id>/AGENTS.md in this repo).
//
// Tools: the crew needs the "coding" tool surface (read/write/edit/exec/glob/grep).
// Set `tools.profile: "coding"` globally OR add per-agent allowlists to taste.
{
  agents: {
    defaults: {
      // --- Compaction -----------------------------------------------------------
      // Keep the reserve explicit so the crew has predictable room for tool-heavy
      // wave work. This is still harmless for large cloud context windows.
      // See docs/NOTES-compaction.md and the upstream bug issue.
      compaction: {
        reserveTokens: 8192,
        reserveTokensFloor: 0,
      },

      subagents: { maxSpawnDepth: 2, maxConcurrent: 5, maxChildrenPerAgent: 8, runTimeoutSeconds: 1200 },
    },
    list: [
      // ---- Orchestrator: drives the wave engine via sessions_spawn ----
      {
        id: "fakoli-orchestrator",
        name: "Fakoli Orchestrator",
        workspace: "~/.openclaw/workspace-fakoli-orchestrator",
        model: "openai/gpt-5.5",
        subagents: {
          maxSpawnDepth: 2,
          delegationMode: "prefer",
          allowAgents: [
            "fakoli-guido", "fakoli-critic", "fakoli-scout", "fakoli-smith",
            "fakoli-welder", "fakoli-herald", "fakoli-keeper", "fakoli-sentinel",
          ],
        },
      },

      // ---- Specialists: cloud (quality-critical) ----
      { id: "fakoli-guido",    name: "Guido (Architect)",    workspace: "~/.openclaw/workspace-fakoli-guido",    model: "openai/gpt-5.5" },
      { id: "fakoli-critic",   name: "Critic (Reviewer)",    workspace: "~/.openclaw/workspace-fakoli-critic",   model: "openai/gpt-5.5" },
      { id: "fakoli-sentinel", name: "Sentinel (QA)",        workspace: "~/.openclaw/workspace-fakoli-sentinel", model: "openai/gpt-5.5" },

      // ---- Specialists: OpenAI efficient tier (parallel workers) ----
      { id: "fakoli-welder",   name: "Welder (Integration)", workspace: "~/.openclaw/workspace-fakoli-welder",   model: "openai/gpt-5.4-mini" },
      { id: "fakoli-smith",    name: "Smith (Plugin Eng)",   workspace: "~/.openclaw/workspace-fakoli-smith",    model: "openai/gpt-5.4-mini" },
      { id: "fakoli-scout",    name: "Scout (Researcher)",   workspace: "~/.openclaw/workspace-fakoli-scout",    model: "openai/gpt-5.4-mini" },
      { id: "fakoli-herald",   name: "Herald (Docs)",        workspace: "~/.openclaw/workspace-fakoli-herald",   model: "openai/gpt-5.4-mini" },
      { id: "fakoli-keeper",   name: "Keeper (Infra)",       workspace: "~/.openclaw/workspace-fakoli-keeper",   model: "openai/gpt-5.4-mini" },
    ],
  },
}
